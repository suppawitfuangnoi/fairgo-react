// FAIRGO - Fair-pricing ride-hailing platform for Thailand
// Prisma Schema - Phase 1

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  CUSTOMER
  DRIVER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum VehicleType {
  TAXI
  MOTORCYCLE
  TUKTUK
}

enum DriverVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocumentType {
  DRIVERS_LICENSE
  NATIONAL_ID
  VEHICLE_REGISTRATION
  INSURANCE
  PROFILE_PHOTO
  VEHICLE_PHOTO
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RideRequestStatus {
  PENDING
  MATCHING
  NEGOTIATING
  MATCHED
  CANCELLED
  EXPIRED
}

enum RideOfferStatus {
  PENDING
  COUNTERED
  ACCEPTED
  REJECTED
  EXPIRED
  WITHDRAWN
}

enum TripStatus {
  DRIVER_ASSIGNED
  DRIVER_EN_ROUTE
  DRIVER_ARRIVED
  PICKUP_CONFIRMED
  IN_PROGRESS
  ARRIVED_DESTINATION
  AWAITING_CASH_CONFIRMATION
  COMPLETED
  CANCELLED
  CANCELLED_BY_PASSENGER
  CANCELLED_BY_DRIVER
  NO_SHOW_PASSENGER
  NO_SHOW_DRIVER
}

enum PaymentMethod {
  CASH
  CARD
  WALLET
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum WalletTransactionType {
  TOP_UP
  RIDE_PAYMENT
  RIDE_EARNING
  WITHDRAWAL
  REFUND
  PROMOTION
  COMMISSION
}

enum NotificationType {
  // ── Core business events ─────────────────────────────────────────
  NEW_RIDE_REQUEST       // Sent to nearby online drivers
  NEW_OFFER              // Sent to customer when driver submits offer
  COUNTER_OFFER          // Sent to either party when counter-offer received
  OFFER_ACCEPTED         // Sent to driver when customer accepts
  OFFER_REJECTED         // Sent to driver when customer rejects
  DRIVER_EN_ROUTE        // Sent to customer when driver starts coming
  DRIVER_ARRIVED         // Sent to customer when driver arrives
  TRIP_STARTED           // Sent to customer when trip begins
  AWAITING_CASH_PAYMENT  // Sent to customer when cash confirmation needed
  PAYMENT_CONFIRMED      // Sent to both parties on payment complete
  TRIP_COMPLETED         // Sent to both parties on trip complete
  TRIP_CANCELLED         // Sent to affected party on cancellation
  DISPUTE_CREATED        // Admin notification on new dispute
  DISPUTE_RESOLVED       // Sent to reporter when admin resolves dispute
  SYSTEM_ALERT           // Platform-wide system messages
  OTP_DEBUG_INFO         // Non-production OTP debug (admin only)
  // ── Legacy (kept for backward compat) ───────────────────────────
  RIDE_REQUEST
  RIDE_OFFER
  RIDE_ACCEPTED
  TRIP_UPDATE
  PAYMENT
  PROMOTION
  SYSTEM
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ==================== MODELS ====================

model User {
  id        String     @id @default(cuid())
  phone     String
  email     String?
  name      String?
  role      UserRole
  status    UserStatus @default(ACTIVE)
  avatarUrl String?
  locale    String     @default("th")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?

  // ── Admin moderation fields ────────────────────────────────────────
  suspendedReason String?   // Reason provided by admin when suspending
  suspendedAt     DateTime? // When the suspension took effect
  isFlagged       Boolean   @default(false)
  flagReason      String?   // Admin-provided flag reason
  flaggedAt       DateTime?
  flaggedBy       String?   // Admin userId who flagged

  customerProfile CustomerProfile?
  driverProfile   DriverProfile?
  adminProfile    AdminProfile?
  refreshTokens   RefreshToken[]
  deviceTokens    DeviceToken[]
  notifications   Notification[]
  ratingsGiven    Rating[]         @relation("RatingFrom")
  ratingsReceived Rating[]         @relation("RatingTo")
  supportTickets  SupportTicket[]
  auditLogs       AuditLog[]

  // เบอร์/อีเมลซ้ำข้าม role ได้ แต่ห้ามซ้ำใน role เดียวกัน
  @@unique([phone, role])
  @@index([phone])
  @@index([role])
  @@index([status])
  @@index([isFlagged])
  @@map("users")
}

model CustomerProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  savedPlaces   Json?    // { home: {lat, lng, address}, work: {lat, lng, address}, ... }
  favoriteDriverIds String[] @default([]) // driverProfile IDs the customer has starred
  defaultPaymentMethod PaymentMethod @default(CASH)
  totalTrips    Int      @default(0)
  averageRating Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  rideRequests RideRequest[]
  wallet       Wallet?

  @@map("customer_profiles")
}

model DriverProfile {
  id                  String                   @id @default(cuid())
  userId              String                   @unique
  licenseNumber       String?
  isOnline            Boolean                  @default(false)
  lastSeenAt          DateTime?
  isVerified          Boolean                  @default(false)
  verificationStatus  DriverVerificationStatus @default(PENDING)
  currentLatitude     Float?
  currentLongitude    Float?
  lastLocationUpdate  DateTime?
  totalTrips          Int                      @default(0)
  averageRating       Float                    @default(0)
  acceptanceRate      Float                    @default(0)
  commissionRate      Float                    @default(0.15) // 15% default
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  // ── Admin moderation fields ────────────────────────────────────────
  isFlagged       Boolean   @default(false)
  flagReason      String?
  flaggedAt       DateTime?
  flaggedBy       String?   // Admin userId
  rejectionReason String?   // Reason when verificationStatus = REJECTED

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicles   Vehicle[]
  documents  DriverDocument[]
  rideOffers RideOffer[]
  trips      Trip[]
  wallet     Wallet?

  @@index([isOnline])
  @@index([verificationStatus])
  @@index([isFlagged])
  @@index([currentLatitude, currentLongitude])
  @@map("driver_profiles")
}

model AdminProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  department  String?
  permissions Json?    // { users: true, drivers: true, trips: true, payments: true, ... }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

model Vehicle {
  id              String      @id @default(cuid())
  driverProfileId String
  type            VehicleType
  make            String      // e.g. Toyota
  model           String      // e.g. Altis
  color           String
  year            Int?
  plateNumber     String
  photoUrl        String?
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  driverProfile DriverProfile @relation(fields: [driverProfileId], references: [id], onDelete: Cascade)
  trips         Trip[]

  @@unique([plateNumber])
  @@index([driverProfileId])
  @@index([type])
  @@map("vehicles")
}

model DriverDocument {
  id              String         @id @default(cuid())
  driverProfileId String
  type            DocumentType
  fileUrl         String
  status          DocumentStatus @default(PENDING)
  rejectionReason String?
  expiresAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  driverProfile DriverProfile @relation(fields: [driverProfileId], references: [id], onDelete: Cascade)

  @@index([driverProfileId])
  @@index([type])
  @@map("driver_documents")
}

model RideRequest {
  id                String            @id @default(cuid())
  customerProfileId String
  vehicleType       VehicleType
  pickupLatitude    Float
  pickupLongitude   Float
  pickupAddress     String
  dropoffLatitude   Float
  dropoffLongitude  Float
  dropoffAddress    String
  fareMin           Float             // Customer's minimum acceptable fare
  fareMax           Float             // Customer's maximum acceptable fare
  fareOffer         Float             // Customer's proposed fare
  recommendedFare   Float?            // System-calculated recommended fare
  estimatedDistance Float?            // in kilometers
  estimatedDuration Int?              // in minutes
  paymentMethod     PaymentMethod     @default(CASH)
  status            RideRequestStatus @default(PENDING)
  expiresAt         DateTime?
  cancelledAt       DateTime?
  cancelReason      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  customerProfile CustomerProfile @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  offers          RideOffer[]
  trip            Trip?

  @@index([customerProfileId])
  @@index([status])
  @@index([vehicleType])
  @@index([pickupLatitude, pickupLongitude])
  @@index([createdAt])
  @@map("ride_requests")
}

model RideOffer {
  id              String          @id @default(cuid())
  rideRequestId   String
  driverProfileId String
  fareAmount      Float           // Offered fare
  estimatedPickupMinutes Int?     // ETA to pickup
  message         String?         // Optional message
  status          RideOfferStatus @default(PENDING)
  proposedBy      String          @default("DRIVER") // "DRIVER" or "CUSTOMER"
  roundNumber     Int             @default(1)          // Negotiation round (max 5)
  parentOfferId   String?         // Links to the offer being countered
  expiresAt       DateTime?       // Auto-expire after 60s for counter-offers
  respondedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  rideRequest   RideRequest   @relation(fields: [rideRequestId], references: [id], onDelete: Cascade)
  driverProfile DriverProfile @relation(fields: [driverProfileId], references: [id], onDelete: Cascade)

  @@index([rideRequestId])
  @@index([driverProfileId])
  @@index([status])
  @@index([expiresAt])
  @@map("ride_offers")
}

model Trip {
  id              String     @id @default(cuid())
  rideRequestId   String     @unique
  driverProfileId String
  vehicleId       String?
  lockedFare      Float      // Final agreed fare
  status          TripStatus @default(DRIVER_ASSIGNED)
  pickupLatitude  Float
  pickupLongitude Float
  pickupAddress   String
  dropoffLatitude  Float
  dropoffLongitude Float
  dropoffAddress   String
  actualDistance   Float?     // in km
  actualDuration  Int?       // in minutes
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  cancelledBy     String?    // userId
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  rideRequest   RideRequest   @relation(fields: [rideRequestId], references: [id], onDelete: Cascade)
  driverProfile DriverProfile @relation(fields: [driverProfileId], references: [id], onDelete: Cascade)
  vehicle       Vehicle?      @relation(fields: [vehicleId], references: [id])
  tripLocations TripLocation[]
  statusLogs    TripStatusLog[]
  payment       Payment?
  ratings       Rating[]

  @@index([driverProfileId])
  @@index([status])
  @@index([createdAt])
  @@map("trips")
}

model TripStatusLog {
  id            String     @id @default(cuid())
  tripId        String
  fromStatus    String     // Previous status (String to avoid enum issues across versions)
  toStatus      String     // New status
  changedByType String     // "DRIVER", "CUSTOMER", "ADMIN", "SYSTEM"
  changedById   String?    // userId who triggered the change
  note          String?    // Optional note (e.g. cancellation reason)
  createdAt     DateTime   @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([createdAt])
  @@map("trip_status_logs")
}

model TripLocation {
  id        String   @id @default(cuid())
  tripId    String
  latitude  Float
  longitude Float
  speed     Float?
  heading   Float?
  timestamp DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([timestamp])
  @@map("trip_locations")
}

model Payment {
  id                    String        @id @default(cuid())
  tripId                String        @unique
  amount                Float
  commission            Float         // Platform commission
  driverEarning         Float         // amount - commission
  method                PaymentMethod
  status                PaymentStatus @default(PENDING)
  transactionRef        String?
  driverConfirmedAt     DateTime?     // When driver confirmed cash received
  passengerConfirmedAt  DateTime?     // When passenger confirmed payment
  paidAt                DateTime?

  // ── Dispute support ───────────────────────────────────────────────
  disputeFlag           Boolean   @default(false)   // true while dispute is open
  disputeReason         String?                     // Passenger-reported reason
  disputeRaisedAt       DateTime?                   // When dispute was raised
  disputeRaisedBy       String?                     // userId of the reporter
  disputeResolvedAt     DateTime?                   // When admin resolved dispute
  disputeResolvedBy     String?                     // adminUserId
  disputeResolutionNote String?                     // Admin resolution note

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([disputeFlag])
  @@index([createdAt])
  @@map("payments")
}

model Wallet {
  id                String   @id @default(cuid())
  customerProfileId String?  @unique
  driverProfileId   String?  @unique
  balance           Float    @default(0)
  currency          String   @default("THB")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customerProfile CustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  driverProfile   DriverProfile?   @relation(fields: [driverProfileId], references: [id], onDelete: Cascade)
  transactions    WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String                @id @default(cuid())
  walletId    String
  type        WalletTransactionType
  amount      Float
  balanceBefore Float
  balanceAfter  Float
  description String?
  referenceId String?               // tripId, etc.
  createdAt   DateTime              @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
  @@map("wallet_transactions")
}

model Rating {
  id        String   @id @default(cuid())
  tripId    String
  fromUserId String
  toUserId   String
  score     Int      // 1-5
  tags      String[] // e.g. ["Fair price", "Friendly driver", "Clean car"]
  comment   String?
  createdAt DateTime @default(now())

  trip     Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  fromUser User @relation("RatingFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("RatingTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([tripId, fromUserId])
  @@index([toUserId])
  @@index([createdAt])
  @@map("ratings")
}

model Notification {
  id                String           @id @default(cuid())
  userId            String
  type              NotificationType
  title             String
  body              String
  relatedEntityType String?          // "trip" | "offer" | "ride" | "payment"
  relatedEntityId   String?          // ID of related entity (tripId, offerId, etc.)
  payload           Json?            // Structured extra data for deep-link / display
  data              Json?            // Legacy field — kept for backward compat
  isRead            Boolean          @default(false)
  readAt            DateTime?
  createdAt         DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   // ios, android, web
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

model PricingRule {
  id             String      @id @default(cuid())
  vehicleType    VehicleType
  baseFare       Float
  perKmRate      Float
  perMinuteRate  Float
  minimumFare    Float
  surgeMultiplier Float     @default(1.0)
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([vehicleType])
  @@map("pricing_rules")
}

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  description     String?
  discountType    String   // PERCENTAGE, FIXED
  discountValue   Float
  maxDiscount     Float?
  minFare         Float?
  maxRedemptions  Int?
  currentRedemptions Int   @default(0)
  validFrom       DateTime
  validUntil      DateTime
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  redemptions CouponRedemption[]

  @@index([code])
  @@index([isActive])
  @@map("coupons")
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  userId    String
  tripId    String?
  discount  Float
  createdAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId, tripId])
  @@index([userId])
  @@map("coupon_redemptions")
}

model SupportTicket {
  id          String                @id @default(cuid())
  userId      String
  tripId      String?
  subject     String
  description String
  status      SupportTicketStatus   @default(OPEN)
  priority    SupportTicketPriority @default(MEDIUM)
  assignedTo  String?
  resolution  String?               // Admin resolution notes
  resolvedAt  DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tripId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@map("support_tickets")
}

// ── Background job distributed-lock registry ─────────────────────────────────
// One row per named job. The atomic ON CONFLICT DO UPDATE WHERE pattern in
// job-lock.ts ensures only one replica can run a given job at a time.
model JobRun {
  jobName    String    @id              // e.g. "otp-cleanup"
  lockedAt   DateTime?                  // NULL when idle
  lockedBy   String?                    // hostname-pid of the holder
  lastRunAt  DateTime?                  // When the last successful run finished
  lastResult Json?                      // Summary from the last run

  @@map("job_runs")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

enum OtpStatus {
  PENDING      // Active, not yet used
  USED         // Successfully verified
  EXPIRED      // Past expiresAt without use
  LOCKED       // Too many failed attempts — locked until lockedUntil
  INVALIDATED  // Replaced by a newer OTP request for the same phone+purpose
}

enum OtpPurpose {
  CUSTOMER_LOGIN  // Customer app login / register
  DRIVER_LOGIN    // Driver app login / register
}

model OtpCode {
  id           String     @id @default(cuid())
  phone        String                           // Always normalised: +66XXXXXXXXX
  code         String                           // 6-digit numeric string
  otpRef       String     @unique               // Human-readable ref e.g. REF-A3F7K2
  purpose      OtpPurpose @default(CUSTOMER_LOGIN)
  status       OtpStatus  @default(PENDING)
  expiresAt    DateTime
  attemptCount Int        @default(0)           // Wrong attempts since last request
  resendCount  Int        @default(0)           // How many times this session has been resent
  lockedUntil  DateTime?                        // Set when brute-force threshold reached
  usedAt       DateTime?                        // When code was successfully used
  ipAddress    String?                          // Requester IP for rate-limit auditing
  userAgent    String?                          // Browser / app user-agent
  metadata     Json?                            // Optional: { deviceType, appVersion, … }
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([phone])
  @@index([phone, purpose, status])
  @@index([otpRef])
  @@index([expiresAt])
  @@map("otp_codes")
}
